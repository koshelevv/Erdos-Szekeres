% Launch this logic program to obtain 10 points edge coloring for R_c(3,4)

#include "ES_Ramsey.lp".
#include "xy2signotope.lp".

#const n=10.
#const tr1=99.
#const quad2=99.

xy(1,0).
xy(2,0).
xy(3,-211).
xy(4,-421).
xy(5,-671).
xy(6,-839).
xy(7,-1044).
xy(8,-1248).
xy(9,-1458).
xy(10,-1655).

xy(X,X,Y) :- xy(X,Y).
